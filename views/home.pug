extends layout

block content
  //- Hero section
  section.sat-hero.text-center.text-white
    .container.py-5
      h1.display-3(style='font-family:"Playfair Display",serif;font-weight:700') Sea Air Towers
      p.lead.mt-3.mb-2 Vacation Rentals &amp; Sales in Hollywood Beach, Florida
      p.fs-5.mb-4 Save 5–10% off Airbnb/Vrbo prices by renting or buying directly from owners (30-day minimum)
      a.btn.btn-accent.btn-lg(href='/search-for-apartments')
        i.bi.bi-search.me-2
        | Search Apartments

  //- Feature cards
  section.bg-sand.py-5
    .container
      .row.g-4.justify-content-center
        .col-md-4
          .sat-feature-card.text-center.p-4
            .sat-feature-icon.mb-3
              i.bi.bi-search.fs-3
            h5 Search
            p.text-muted Search for apartments by bedrooms, bathrooms, and availability dates.
            a.btn.btn-outline-ocean.btn-sm(href='/search-for-apartments') Browse Listings
        .col-md-4
          .sat-feature-card.text-center.p-4
            .sat-feature-icon.mb-3
              i.bi.bi-plus-circle.fs-3
            h5 List
            p.text-muted Landlords, list your apartment for rent or sale.
            a.btn.btn-outline-ocean.btn-sm(href='/account/list-apartment') List Apartment
        .col-md-4
          .sat-feature-card.text-center.p-4
            .sat-feature-icon.mb-3
              i.bi.bi-pencil-square.fs-3
            h5 Update Listing
            p.text-muted Update your apartment details or availability.
            a.btn.btn-outline-ocean.btn-sm(href='/account/update-listing') Update Listing

  //- Photo carousel
  section.py-5
    .container
      h2.text-center.mb-4(style='font-family:"Playfair Display",serif') Our Property
      .sat-carousel.mx-auto(style='max-width:886px')
        #homeCarousel.carousel.slide(data-bs-ride='carousel')
          .carousel-inner
            .carousel-item.active
              img.d-block.w-100(src='/images/IMG-1783.jpg' alt='Image 1 of Sea Air Towers condominium')
            .carousel-item
              img.d-block.w-100(src='/images/IMG-1813.jpg' alt='Image 2 of Sea Air Towers condominium')
            .carousel-item
              img.d-block.w-100(src='/images/7-25.jpg' alt='Image 3 of Sea Air Towers condominium')
            .carousel-item
              img.d-block.w-100(src='/images/7-25-1.jpg' alt='Image 4 of Sea Air Towers condominium')
            .carousel-item
              img.d-block.w-100(src='/images/IMG-6137-1.jpg' alt='Image 5 of Sea Air Towers condominium')
            .carousel-item
              img.d-block.w-100(src='/images/z.jpg' alt='Image 6 of Sea Air Towers condominium')
          button.carousel-control-prev(type='button' data-bs-target='#homeCarousel' data-bs-slide='prev')
            span.carousel-control-prev-icon(aria-hidden='true')
            span.visually-hidden Previous
          button.carousel-control-next(type='button' data-bs-target='#homeCarousel' data-bs-slide='next')
            span.carousel-control-next-icon(aria-hidden='true')
            span.visually-hidden Next

  //- Map section
  section.bg-sand.py-5
    .container.text-center
      h2.mb-4(style='font-family:"Playfair Display",serif') Location
      .sat-map.mx-auto(style='max-width:886px')
        iframe.w-100(src='https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3586.333470043927!2d-80.12038088601203!3d25.989891505463074!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88d9ab5e5a4e20a9%3A0xc9b1f1231a79bbd9!2sSea%20Air%20Towers!5e0!3m2!1sen!2sus!4v1578549406853!5m2!1sen!2sus' height='487' style='border:0' allowfullscreen loading='lazy')
      p.text-muted.mt-3
        i.bi.bi-geo-alt.me-1
        | 3725 S Ocean Dr, Hollywood, FL 33019
