extends ../layout

block content
  .sat-page-header
    .container
      h2 Create Account
      p.mb-0 For landlords listing apartments

  .container.py-5
    .sat-auth-card.sat-card-static
      form.sat-form(id='signup-form', method='POST')
        input(type='hidden', name='_csrf', value=_csrf)
        .mb-3
          label.form-label(for='email') Email
          input.form-control(type='email', name='email', id='email', placeholder='you@example.com', autofocus, required)
        .mb-3
          label.form-label(for='password') Password
          input.form-control(type='password', name='password', id='password', placeholder='Password', required)
        .mb-3
          label.form-label(for='confirmPassword') Confirm Password
          input.form-control(type='password', name='confirmPassword', id='confirmPassword', placeholder='Confirm Password', required)
        .alert.alert-warning.border-0.py-2
          small
            i.bi.bi-shield-exclamation.me-1
            | Use a unique password — do not reuse one from another site.
        button.btn.btn-ocean.w-100(type='submit')
          i.bi.bi-person-plus.me-1
          | Sign Up
      .text-center.mt-3
        small Already have an account?
          a.text-ocean.ms-1(href='/login') Sign in
