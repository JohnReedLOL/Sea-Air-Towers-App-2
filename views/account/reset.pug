extends ../layout

block content
  .sat-page-header
    .container
      h2 Set New Password

  .container.py-5
    .sat-auth-card.sat-card-static
      form.sat-form(method='POST')
        input(type='hidden', name='_csrf', value=_csrf)
        .mb-3
          label.form-label(for='password') New Password
          input.form-control(type='password', name='password', id='password', placeholder='New password', autofocus, required)
        .mb-3
          label.form-label(for='confirm') Confirm Password
          input.form-control(type='password', name='confirm', id='confirm', placeholder='Confirm password', required)
        small.text-muted.d-block.mb-3
          i.bi.bi-info-circle.me-1
          | Choose a unique password that you don't use on other websites.
        button.btn.btn-ocean.w-100(type='submit')
          i.bi.bi-lock.me-1
          | Set New Password
