extends ../layout

block content
  .sat-page-header
    h2 Reset Password

  .container.py-5
    .sat-auth-card.sat-card-static
      p.text-muted Enter the email address associated with your account and we'll help you reset your password.
      form.sat-form(method='POST')
        input(type='hidden', name='_csrf', value=_csrf)
        .mb-3
          label.form-label(for='email') Email
          input.form-control(type='email', name='email', id='email', placeholder='you@example.com', autofocus, required)
        button.btn.btn-ocean.w-100(type='submit')
          i.bi.bi-key.me-1
          | Reset Password
