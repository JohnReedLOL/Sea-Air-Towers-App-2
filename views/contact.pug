extends layout

block content
  section.sat-page-header.text-center.text-white
    .container.py-4
      h1(style='font-family:"Playfair Display",serif') Contact

  section.py-5
    .container(style='max-width:640px')
      .sat-card-static.p-4.p-md-5
        .text-center.mb-4
          i.bi.bi-envelope.fs-1.text-ocean
        h4.text-center.mb-3 Get in Touch
        p If you run into any issues with the site, please reach out to the developer:
        p.text-center.fw-semibold
          i.bi.bi-envelope.me-2
          | JohnMichaelReedFAS AT Gmail DOT com
        p.text-muted.text-center.small Replace AT with an @ and DOT with a .
        hr
        h6.mt-4 Known Issues
        ul.text-muted
          li The collapsed navigation bar may overlap page titles on devices with large font sizes.
          li Sign-in may occasionally require a second attempt — simply re-enter your password.
