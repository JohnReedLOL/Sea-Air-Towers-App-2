extends layout

block content
  section.sat-page-header.text-center.text-white
    .container.py-4
      h1(style='font-family:"Playfair Display",serif') Add to Home Screen

  section.py-5
    .container(style='max-width:720px')
      p.lead.text-center.mb-4 Add a shortcut to this website on your phone's Home Screen for quick access.

      //- Steps
      .row.g-3.mb-5
        .col-12
          .sat-card-static.p-3.d-flex.align-items-start
            span.badge.bg-ocean.rounded-circle.me-3.fs-5(style='width:2.5rem;height:2.5rem;line-height:2.5rem;text-align:center;flex-shrink:0') 1
            div
              h6.mb-1 Open in Your Browser
              p.text-muted.mb-0 Navigate to this website in Safari (iPhone) or Chrome (Android).
        .col-12
          .sat-card-static.p-3.d-flex.align-items-start
            span.badge.bg-ocean.rounded-circle.me-3.fs-5(style='width:2.5rem;height:2.5rem;line-height:2.5rem;text-align:center;flex-shrink:0') 2
            div
              h6.mb-1 Tap the Share Button
              p.text-muted.mb-0 On iPhone, tap the Share arrow (📤). On Android, open the browser menu (⋮).
        .col-12
          .sat-card-static.p-3.d-flex.align-items-start
            span.badge.bg-ocean.rounded-circle.me-3.fs-5(style='width:2.5rem;height:2.5rem;line-height:2.5rem;text-align:center;flex-shrink:0') 3
            div
              h6.mb-1 Add to Home Screen
              p.text-muted.mb-0 Select "Add to Home Screen" (📲) and confirm. A shortcut icon will appear on your Home Screen.

      //- Screenshot carousel
      h5.text-center.mb-3 iPhone Safari — Step-by-Step Screenshots
      .sat-carousel.mx-auto(style='max-width:400px')
        #shortcutCarousel.carousel.slide(data-bs-ride='carousel')
          .carousel-inner
            .carousel-item.active
              img.d-block.w-100(src='/images/Screenshot_2025-05-17_at_6.10.26_AM.png' alt='Screenshot 1 of iPhone')
            .carousel-item
              img.d-block.w-100(src='/images/Sea_Air_Towers_URL_Screenshot.png' alt='Screenshot 2 of iPhone')
            .carousel-item
              img.d-block.w-100(src='/images/Sea_Air_Towers_Vacation_Apartment_Rentals.png' alt='Screenshot 3 of iPhone')
            .carousel-item
              img.d-block.w-100(src='/images/Screenshot_iPhone_Add_To_Home_Screen.png' alt='Screenshot 4 of iPhone')
            .carousel-item
              img.d-block.w-100(src='/images/Screenshot_2025-05-17_at_6.24.23_AM.png' alt='Screenshot 5 of iPhone')
            .carousel-item
              img.d-block.w-100(src='/images/Screenshot_iPhone_2025-05-17_at_6.26.37_AM.png' alt='Screenshot 6 of iPhone')
          button.carousel-control-prev(type='button' data-bs-target='#shortcutCarousel' data-bs-slide='prev')
            span.carousel-control-prev-icon(aria-hidden='true')
            span.visually-hidden Previous
          button.carousel-control-next(type='button' data-bs-target='#shortcutCarousel' data-bs-slide='next')
            span.carousel-control-next-icon(aria-hidden='true')
            span.visually-hidden Next

      hr.my-5
      .text-center.text-muted
        p.mb-1 Website developed by John Michael Reed
        p.small
          | Questions? Email JohnMichaelReedFAS AT Gmail DOT com
          br
          | (Replace AT with @ and DOT with .)
