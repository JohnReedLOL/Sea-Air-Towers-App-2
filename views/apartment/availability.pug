extends ../layout

block content

  - var todaysDateObject = new Date();
  - var todaysDateString = todaysDateObject.toLocaleDateString();
  - var nextDateObjectNew = new Date(todaysDateObject.valueOf());
  - nextDateObjectNew.setDate(nextDateObjectNew.getDate() + 5);
  - var nextDateString = nextDateObjectNew.toLocaleDateString();
  - var dateRange = todaysDateString + " - " + nextDateString

  .sat-page-header
    h2 #{title}

  .container.py-4
    .row.g-4
      .col-md-6
        .sat-card-static.p-4
          h5.mb-3(style='color: #198754;')
            i.bi.bi-calendar-plus.me-2
            | Book Dates
          form.sat-form(action='/account/update-availability/' + apartmentNumber, method='POST')
            input(type='hidden', name='_csrf', value=_csrf)
            .mb-3
              label.form-label(for='dateRange') Date Range
              input.form-control(type='text', name='dateRange', id='dateRange', value=dateRange)
            button.btn.btn-ocean(type='submit')
              i.bi.bi-calendar-check.me-1
              | Book Dates
      .col-md-6
        .sat-card-static.p-4
          h5.mb-3(style='color: #e07a5f;')
            i.bi.bi-calendar-minus.me-2
            | Unbook Dates
          form.sat-form(action='/account/unupdate-availability/' + apartmentNumber, method='POST')
            input(type='hidden', name='_csrf', value=_csrf)
            .mb-3
              label.form-label(for='dateRange2') Date Range
              input.form-control(type='text', name='dateRange2', id='dateRange2', value=dateRange)
            button.btn.btn-outline-ocean(type='submit')
              i.bi.bi-calendar-x.me-1
              | Unbook Dates