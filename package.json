{
    "name": "express-typescript-starter",
    "version": "0.1.0",
    "description": "A starting point for Node.js express apps with TypeScript",
    "repository": {
        "type": "git",
        "url": "https://github.com/Microsoft/TypeScript-Node-Starter"
    },
    "author": "Bowden Kelly",
    "license": "MIT",
    "scripts": {
        "build-sass": "sass src/public/css/main.scss dist/public/css/main.css",
        "build-ts": "tsc",
        "build": "npm run build-sass && npm run build-ts && npm run lint && npm run copy-static-assets",
        "copy-static-assets": "ts-node copyStaticAssets.ts",
        "debug": "npm run build && npm run watch-debug",
        "lint": "tsc --noEmit && eslint \"**/*.{js,ts}\" --quiet --fix",
        "serve-debug": "nodemon --inspect dist/server.js",
        "serve": "node --trace-deprecation dist/server.js",
        "start": "npm run serve",
        "test": "jest --forceExit --coverage --verbose",
        "watch-debug": "concurrently -k -p \"[{name}]\" -n \"Sass,TypeScript,Node\" -c \"yellow.bold,cyan.bold,green.bold\" \"npm run watch-sass\" \"npm run watch-ts\" \"npm run serve-debug\"",
        "watch-node": "nodemon dist/server.js",
        "watch-sass": "sass --watch src/public/css/main.scss dist/public/css/main.css",
        "watch-test": "npm run test -- --watchAll",
        "watch-ts": "tsc -w",
        "watch": "concurrently -k -p \"[{name}]\" -n \"Sass,TypeScript,Node\" -c \"yellow.bold,cyan.bold,green.bold\" \"npm run watch-sass\" \"npm run watch-ts\" \"npm run watch-node\""
    },
    "dependencies": {
        "async": "3.2.6",
        "bcryptjs": "3.0.3",
        "body-parser": "1.20.3",
        "compression": "1.8.1",
        "connect-mongo": "6.0.0",
        "dotenv": "16.6.1",
        "errorhandler": "1.5.2",
        "express": "4.22.1",
        "express-flash": "0.0.2",
        "express-session": "1.19.0",
        "express-validator": "7.3.2",
        "fbgraph": "1.4.4",
        "lodash": "^4.17.21",
        "lusca": "1.7.0",
        "mongoose": "8.14.3",
        "nodemailer": "8.0.5",
        "passport": "0.7.0",
        "passport-facebook": "3.0.0",
        "passport-local": "1.0.0",
        "pug": "3.0.4",
        "winston": "3.19.0"
    },
    "devDependencies": {
        "@types/async": "3.2.25",
        "@types/bcryptjs": "3.0.0",
        "@types/body-parser": "1.19.6",
        "@types/chai": "4.3.20",
        "@types/compression": "1.8.1",
        "@types/errorhandler": "1.5.3",
        "@types/express": "4.17.25",
        "@types/express-flash": "0.0.5",
        "@types/express-session": "1.18.2",
        "@types/jest": "29.5.14",
        "@types/jquery": "3.5.32",
        "@types/lodash": "^4.17.24",
        "@types/lusca": "1.7.5",
        "@types/node": "^22.15.0",
        "@types/nodemailer": "6.4.17",
        "@types/passport": "1.0.17",
        "@types/passport-facebook": "3.0.4",
        "@types/passport-local": "1.0.38",
        "@types/pug": "2.0.10",
        "@types/shelljs": "0.8.17",
        "@types/supertest": "6.0.2",
        "chai": "4.5.0",
        "concurrently": "9.2.1",
        "eslint": "9.28.0",
        "jest": "29.7.0",
        "nodemon": "3.1.14",
        "sass": "1.89.2",
        "shelljs": "0.8.5",
        "supertest": "7.2.2",
        "ts-jest": "29.4.9",
        "ts-node": "10.9.2",
        "typescript": "5.9.3",
        "typescript-eslint": "8.58.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}